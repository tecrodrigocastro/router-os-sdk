{
    "name": "tecrodrigocastro/router-os-sdk",
    "type": "library",
    "description": "Async-capable Mikrotik RouterOS API client for PHP (Fiber-based, optional Swoole transport, Laravel/Hyperf integrations)",
    "keywords": [
        "routeros",
        "mikrotik",
        "socket-client",
        "async",
        "fibers",
        "swoole",
        "laravel",
        "hyperf"
    ],
    "license": "MIT",
    "homepage": "https://github.com/tecrodrigocastro/router-os-sdk",
    "support": {
        "issues": "https://github.com/tecrodrigocastro/router-os-sdk/issues",
        "source": "https://github.com/tecrodrigocastro/router-os-sdk"
    },
    "authors": [
        {
            "name": "Rodrigo Castro",
            "email": "redrodrigo.dev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "suggest": {
        "ext-swoole": "Enables non-blocking coroutine transport under Hyperf and Laravel Octane (Swoole mode)",
        "illuminate/support": "For the Laravel ServiceProvider/Facade integration",
        "hyperf/pool": "For the Hyperf coroutine connection pool integration"
    },
    "autoload": {
        "psr-4": {
            "RouterOS\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RouterOS\\Sdk\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
